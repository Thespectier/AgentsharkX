{
  "name": "@agentsharkx/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run typecheck && npm run test && npm run build",
    "playwright:install": "PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright playwright install chromium",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright playwright test",
    "test:a11y": "PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright playwright test tests/accessibility.spec.ts",
    "test:visual": "PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright playwright test tests/visual.spec.ts",
    "test:visual:update": "PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright playwright test tests/visual.spec.ts --update-snapshots",
    "lighthouse": "PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright node scripts/lighthouse.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.3",
    "@tanstack/react-router": "1.170.18",
    "lucide-react": "1.25.0",
    "motion": "12.42.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "3.10.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.3",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "chrome-launcher": "1.2.1",
    "jsdom": "29.1.1",
    "lighthouse": "13.4.1",
    "msw": "2.15.0",
    "prettier": "3.9.6",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
