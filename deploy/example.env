AGENTSHARK_LISTEN_ADDR=0.0.0.0:8080
AGENTSHARK_ENVIRONMENT=local
AGENTSHARK_ADMIN_TOKEN=change-me-before-use
AGENTSHARK_AUTH_DISABLED=false
AGENTSHARK_COOKIE_SECURE=true
AGENTSHARK_BIND=127.0.0.1
AGENTSHARK_PORT=8080
AGENTSHARK_UPSTREAM_TIMEOUT=3s
AGENTSHARK_UPSTREAM_RETRY_MAX=1
AGENTSHARK_SCAN_TIMEOUT=90s

AGENTGATEWAY_BASE_URL=http://agentgateway:15000
AGENTGATEWAY_ADMIN_TOKEN=
AGENTGATEWAY_CONSOLE_URL=http://localhost:15000/ui
AGENTGATEWAY_RUNTIME_MODE=standalone
# auto selects Docker Desktop bridging or native Linux host networking.
AGENTGATEWAY_DOCKER_HOST_MODE=auto
AGENTGATEWAY_ADMIN_BIND=127.0.0.1
AGENTGATEWAY_ADMIN_PORT=15000
AGENTGATEWAY_METRICS_BIND=127.0.0.1
AGENTGATEWAY_METRICS_PORT=15020
AGENTGATEWAY_READINESS_BIND=127.0.0.1
AGENTGATEWAY_READINESS_PORT=15021
# preview-bootstrap replaces these with the owner of deploy/agentgateway/config.yaml.
AGENTGATEWAY_RUNTIME_UID=65532
AGENTGATEWAY_RUNTIME_GID=65532

AGENTGUARD_BASE_URL=http://agentguard:38080
AGENTGUARD_ADMIN_TOKEN=change-me-before-use
AGENTGUARD_CONSOLE_URL=http://localhost:38008
AGENTGUARD_API_BIND=127.0.0.1
AGENTGUARD_API_PORT=38080
AGENTGUARD_CONSOLE_BIND=127.0.0.1
AGENTGUARD_CONSOLE_PORT=38008
AGENTGUARD_SERVER_PLUGIN_CONFIG=./config/plugins.json
AGENTGUARD_POLICY=
AGENTGUARD_LLM_BASE_URL=
AGENTGUARD_LLM_MODEL=
AGENTGUARD_LLM_API_KEY=
# Thought-Aligner is opt-in. Also select plugins.thought-aligner.example.json.
THOUGHT_ALIGNER_BASE_URL=
THOUGHT_ALIGNER_MODEL=
THOUGHT_ALIGNER_API_KEY=

AGENTSHARK_POLL_INTERVAL=2s
AGENTSHARK_REDACT_PAYLOADS=true
