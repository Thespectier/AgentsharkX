{
  "llm": {
    "port": 4000,
    "providers": [
      { "name": "openai-shared", "provider": "openai" }
    ],
    "models": [
      { "name": "openai/*", "provider": "openai" },
      { "name": "fast", "provider": { "reference": "openai-shared" }, "params": { "model": "gpt-5.4-nano" } }
    ],
    "virtualModels": [
      {
        "name": "resilient",
        "routing": {
          "failover": {
            "targets": [
              { "model": "openai/gpt-5.4-nano", "priority": 0 },
              { "model": "anthropic/claude-haiku-4-5", "priority": 1 }
            ]
          }
        }
      }
    ]
  },
  "mcp": {
    "targets": [
      { "name": "everything", "mcp": { "host": "http://localhost:3001/mcp" } }
    ]
  },
  "binds": [
    {
      "port": 8080,
      "listeners": [
        {
          "name": "public-http",
          "hostname": "example.com",
          "protocol": "HTTP",
          "routes": [
            {
              "name": "api",
              "hostnames": ["example.com"],
              "matches": [{ "path": { "pathPrefix": "/api" } }],
              "policies": {
                "cors": { "allowOrigins": ["https://console.example.invalid"] },
                "ai": {
                  "promptGuard": {
                    "request": { "regex": { "patterns": ["<sanitized>"] } },
                    "response": { "webhook": { "url": "https://guardrail.example.invalid" } }
                  }
                }
              },
              "backends": [
                {
                  "host": "localhost:9000",
                  "policies": { "backendAuth": { "token": "<redacted>" } }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "port": 9090,
      "listeners": [
        {
          "name": "tcp",
          "hostname": "tcp.example.com",
          "protocol": "TCP",
          "tcpRoutes": [
            {
              "name": "tcp-main",
              "hostnames": ["tcp.example.com"],
              "backends": [{ "host": "localhost:3306" }]
            }
          ]
        }
      ]
    }
  ]
}
